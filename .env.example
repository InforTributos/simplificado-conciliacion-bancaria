# =============================================================================
# Concilia /procesar API — Environment Variables
# Copiar a .env y descomentar/rellenar las variables necesarias.
# Sin LLM_API_KEY solo funcionan los parsers regex (16 bancos colombianos).
# =============================================================================

# Server
APP_PORT=8000
APP_HOST=0.0.0.0
MAX_FILE_SIZE_MB=50

# LLM / Vision
LLM_API_KEY=nvapi-key-del-cliente-aqui
NVIDIA_API_KEY=nvapi-key-de-la-empresa-aqui
HF_API_KEY=hf_key_de_la_empresa_aqui
